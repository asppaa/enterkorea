---
import BaseLayout from '../components/BaseLayout.astro';
import AdSlot from '../components/AdSlot.astro';
import LineChart from '../components/LineChart.astro';
import TelegramInvite from '../components/TelegramInvite.astro';
import { marketMeta, riskSnapshotFallback } from '../data/market';
import { sitePages } from '../data/site';
import { getApiBase } from '../lib/runtime';

const page = sitePages.find((item) => item.path === '/risk')!;
const apiBase = getApiBase(import.meta.env.PUBLIC_KIMP_API_BASE, import.meta.env.DEV);

const signedPercent = (value: number, digits = 2) => `${value > 0 ? '+' : ''}${value.toFixed(digits)}%`;

const fallbackSignals = [
  {
    id: 'kimp-index',
    title: 'KIMP Index',
    label: `${signedPercent(riskSnapshotFallback.kimpIndexValue)} · ${riskSnapshotFallback.kimpIndexLabel}`,
    note: 'BTC·ETH·USDT 가중 평균 한국 프리미엄',
    tone: 'normal',
  },
  { id: 'fear-greed', title: '코인 F&G (Crypto)', label: riskSnapshotFallback.fearGreedLabel, note: '코인 시장 심리 (alternative.me)', tone: 'watch' },
  { id: 'fear-greed-cnn', title: '미국증시 F&G (CNN)', label: 'Neutral', note: '미국 주식 심리 (CNN Business)', tone: 'normal' },
  { id: 'usd-krw', title: 'USD/KRW', label: `${riskSnapshotFallback.usdKrw.toFixed(2)}`, note: '환율 스트레스 체크', tone: 'danger' },
  { id: 'btc-global', title: 'BTC 한국/해외', label: '+0.05%', note: '대표 코인 프리미엄', tone: 'normal' },
  { id: 'btc-domestic', title: 'BTC 국내 거래소', label: '+0.01%', note: '한국 내부 수급 보조 신호', tone: 'normal' },
  { id: 'btc-funding', title: 'BTC 선물 펀딩비', label: signedPercent(riskSnapshotFallback.btcFundingRate * 100, 4), note: '선물 포지션 쏠림 체크', tone: 'normal' },
  { id: 'btc-open-interest', title: 'BTC OI 24h 변화', label: signedPercent(riskSnapshotFallback.btcOpenInterestChange24h), note: '청산 대리지표', tone: 'normal' },
];
---

<BaseLayout title={page.title} description={page.description} locale="ko" pathname={page.path}>
  <section class="hero">
    <div class="hero-compact">
      <div class="hero-topline">
        <div>
          <div class="eyebrow">한국 프리미엄 관측소 · 위험 신호</div>
          <h1>한 번에 보는 위험 신호</h1>
        </div>
        <div class="hero-badges">
          <div class="lang-badge" id="risk-live-status">{apiBase ? '실시간 연결 대기 중' : `스냅샷 · ${marketMeta.updatedAt}`}</div>
          <div class="lang-badge">{marketMeta.cacheWindowSeconds}초 갱신</div>
        </div>
      </div>
      <div class="summary-grid">
        <article class="summary-card summary-card-primary">
          <strong>KIMP Index</strong>
          <span id="risk-kimp-index">{signedPercent(riskSnapshotFallback.kimpIndexValue)}</span>
          <p id="risk-kimp-index-label">{riskSnapshotFallback.kimpIndexLabel}</p>
        </article>
        <article class="summary-card summary-card-primary">
          <strong>코인 F&G (Crypto)</strong>
          <span id="risk-fear-greed">{riskSnapshotFallback.fearGreedValue}</span>
          <p id="risk-fear-greed-label">{riskSnapshotFallback.fearGreedLabel}</p>
        </article>
        <article class="summary-card summary-card-primary">
          <strong>미국증시 F&G (CNN)</strong>
          <span id="risk-fear-greed-cnn">47</span>
          <p id="risk-fear-greed-cnn-label">Neutral</p>
        </article>
        <article class="summary-card">
          <strong>USD/KRW</strong>
          <span id="risk-usdkrw">{riskSnapshotFallback.usdKrw.toFixed(2)}</span>
          <p>환율 스트레스</p>
        </article>
        <article class="summary-card">
          <strong>BTC 한국/해외</strong>
          <span id="risk-btc-global">+0.05%</span>
          <p>대표 코인 프리미엄</p>
        </article>
        <article class="summary-card">
          <strong>BTC 국내 거래소</strong>
          <span id="risk-btc-domestic">+0.01%</span>
          <p>한국 내부 수급</p>
        </article>
        <article class="summary-card">
          <strong>BTC 펀딩비</strong>
          <span id="risk-btc-funding">{signedPercent(riskSnapshotFallback.btcFundingRate * 100, 4)}</span>
          <p>선물 포지션 쏠림</p>
        </article>
        <article class="summary-card">
          <strong>BTC OI 24h</strong>
          <span id="risk-btc-oi">{signedPercent(riskSnapshotFallback.btcOpenInterestChange24h)}</span>
          <p>청산 대리지표</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section dashboard-grid">
    <LineChart
      title="Fear & Greed 7일 흐름"
      value={`코인 ${riskSnapshotFallback.fearGreedValue} · 미국증시 47`}
      caption="코인(Crypto · alternative.me) vs 미국증시(CNN)"
      values={riskSnapshotFallback.fearGreedHistory}
      valuesSecondary={[55, 52, 49, 48, 47, 46, 47]}
      primaryLabel="코인 F&G (Crypto)"
      secondaryLabel="미국증시 F&G (CNN)"
    />
    <article class="copy-panel compact-panel">
      <h2>왜 이 페이지가 필요한가</h2>
      <ul class="bullet-list">
        <li>김프 숫자만 보면 환율과 심리 변수에 가려진 위험을 놓칠 수 있습니다.</li>
        <li>코인·ETF·원자재 괴리율을 같은 시점에 보면 한국 시장의 체감 온도가 더 잘 보입니다.</li>
        <li>텔레그램 채널에서는 이 신호를 더 짧고 자주 요약하는 방식이 잘 맞습니다.</li>
      </ul>
    </article>
  </section>

  <section class="section">
    <article class="panel">
      <div class="section-header">
        <div>
          <h2>위험 신호 보드</h2>
          <p>KIMP Index, Fear & Greed, 환율, BTC 스프레드, 펀딩비, OI를 한 번에 묶습니다.</p>
        </div>
      </div>
      <div class="signal-grid" id="risk-signal-grid">
        {
          fallbackSignals.map((signal) => (
            <article class:list={['signal-card', `signal-${signal.tone}`]}>
              <strong>{signal.title}</strong>
              <span>{signal.label}</span>
              <p>{signal.note}</p>
            </article>
          ))
        }
      </div>
    </article>
  </section>

  <section class="section">
    <article class="panel">
      <div class="section-header">
        <div>
          <h2>위험 신호가 높을 때 확인할 것</h2>
          <p>위험 신호는 매도 신호가 아닙니다. 다만 여러 지표가 동시에 비정상 구간에 들어가면 포지션 규모와 유동성 리스크를 점검할 필요가 있습니다.</p>
        </div>
      </div>
      <div class="table-scroll">
        <table class="checklist-table">
          <thead>
            <tr>
              <th>신호</th>
              <th>확인할 것</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>USDT 김프 급등</td><td>원화 기반 달러 수요가 강한지, 거래소 입출금 제한 이슈가 있는지 확인합니다.</td></tr>
            <tr><td>BTC 김프 급등</td><td>국내 개인투자자 과열인지, 해외 BTC 가격과 같은 방향으로 움직이는지 확인합니다.</td></tr>
            <tr><td>국내 거래소 차이 확대</td><td>특정 거래소의 유동성 부족, 입출금 지연, 호가 왜곡 여부를 확인합니다.</td></tr>
            <tr><td>ETF 괴리율 확대</td><td>장중 NAV 시차, 환율 반영 지연, 거래량 부족 여부를 확인합니다.</td></tr>
            <tr><td>원자재 프리미엄 확대</td><td>원자재 자체 상승인지, 국내 ETF 유동성 문제인지 구분합니다.</td></tr>
            <tr><td>Fear &amp; Greed 급락</td><td>위험자산 회피 심리와 김프 방향이 일치하는지 확인합니다.</td></tr>
            <tr><td>USD/KRW 급등</td><td>김프가 진짜 과열인지, 단순 환율 효과인지 확인합니다.</td></tr>
          </tbody>
        </table>
      </div>
    </article>
  </section>

  <section class="section">
    <TelegramInvite title="위험 신호 텔레그램 · X 연결" note="이 페이지가 분석판이라면, 텔레그램은 빠른 경보판이고 X는 더 짧은 업데이트 흐름으로 연결됩니다." />
  </section>

  <section class="section">
    <AdSlot label="위험 신호 구글 애드센스 자리" note="신호 카드 아래에서 자연스럽게 이어지도록 확보해 둔 애드센스 자리입니다." />
  </section>
</BaseLayout>

<script define:vars={{ apiBase }}>
  const liveStatus = document.getElementById('risk-live-status');
  const kimpIndex = document.getElementById('risk-kimp-index');
  const kimpIndexLabel = document.getElementById('risk-kimp-index-label');
  const fearGreed = document.getElementById('risk-fear-greed');
  const fearGreedLabel = document.getElementById('risk-fear-greed-label');
  const fearGreedCnn = document.getElementById('risk-fear-greed-cnn');
  const fearGreedCnnLabel = document.getElementById('risk-fear-greed-cnn-label');
  const usdKrw = document.getElementById('risk-usdkrw');
  const btcGlobal = document.getElementById('risk-btc-global');
  const btcDomestic = document.getElementById('risk-btc-domestic');
  const btcFunding = document.getElementById('risk-btc-funding');
  const btcOpenInterest = document.getElementById('risk-btc-oi');
  const signalGrid = document.getElementById('risk-signal-grid');

  const formatPercent = (value) =>
    value === null || value === undefined ? '-' : `${Number(value) > 0 ? '+' : ''}${Number(value).toFixed(2)}%`;
  const formatFunding = (value) =>
    value === null || value === undefined ? '-' : `${Number(value) > 0 ? '+' : ''}${(Number(value) * 100).toFixed(4)}%`;

  const toneClass = (tone) => `signal-card signal-${tone || 'normal'}`;

  const renderSignals = (signals) => {
    if (!signalGrid || !Array.isArray(signals)) return;

    signalGrid.innerHTML = signals.map((signal) => `
      <article class="${toneClass(signal.tone)}">
        <strong>${signal.title}</strong>
        <span>${signal.label}</span>
        <p>${signal.note}</p>
      </article>
    `).join('');
  };

  const load = async () => {
    if (!apiBase) return;

    try {
      const response = await fetch(`${apiBase}/api/risk`);
      const payload = await response.json();

      if (liveStatus) liveStatus.textContent = payload.fallback ? '폴백 데이터 표시 중' : `실시간 · ${payload.updatedAt}`;
      if (kimpIndex) kimpIndex.textContent = formatPercent(payload.kimpIndex?.value);
      if (kimpIndexLabel) kimpIndexLabel.textContent = payload.kimpIndex?.label ?? '-';
      if (fearGreed) fearGreed.textContent = String(payload.fearGreed?.value ?? '-');
      if (fearGreedLabel) fearGreedLabel.textContent = payload.fearGreed?.label ?? '-';
      if (fearGreedCnn) fearGreedCnn.textContent = payload.fearGreedCnn?.value != null ? String(payload.fearGreedCnn.value) : '-';
      if (fearGreedCnnLabel) fearGreedCnnLabel.textContent = payload.fearGreedCnn?.label ?? '-';
      if (usdKrw) usdKrw.textContent = Number(payload.usdKrw ?? 0).toFixed(2);
      if (btcGlobal) btcGlobal.textContent = formatPercent(payload.btcGlobalPremium);
      if (btcDomestic) btcDomestic.textContent = formatPercent(payload.btcDomesticPremium);
      if (btcFunding) btcFunding.textContent = formatFunding(payload.btcFunding?.rate);
      if (btcOpenInterest) btcOpenInterest.textContent = formatPercent(payload.btcOpenInterest?.change24hPercent);
      renderSignals(payload.signals);
    } catch {
      if (liveStatus) liveStatus.textContent = '실시간 연결 실패 · 폴백 유지';
    }
  };

  load();
  if (apiBase) window.setInterval(load, 3000);
</script>

---
import BaseLayout from '../components/BaseLayout.astro';
import CoinDetailSection from '../components/CoinDetailSection.astro';
import Calculator from '../components/Calculator.astro';
import { coinSnapshots } from '../data/market';
import { sitePages } from '../data/site';

const page = sitePages.find((item) => item.path === '/btc')!;
---

<BaseLayout
  title={page.title}
  description={page.description}
  locale="ko"
  pathname={page.path}
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: page.title,
    inLanguage: 'ko',
    description: page.description,
  }}
>
  <CoinDetailSection coin={coinSnapshots.BTC} pageLabel="BTC 상세 랜딩" />
  <section class="section">
    <Calculator heading="비트코인 김프 계산기" />
  </section>
</BaseLayout>

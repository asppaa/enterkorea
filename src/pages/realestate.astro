---
import BaseLayout from '../components/BaseLayout.astro';
import { sitePages } from '../data/site';
import { getApiBase } from '../lib/runtime';

const page = sitePages.find((item) => item.path === '/realestate')!;
const apiBase = getApiBase(import.meta.env.PUBLIC_KIMP_API_BASE, import.meta.env.DEV);
---

<BaseLayout title={page.title} description={page.description} locale="ko" pathname={page.path}>
  <section class="hero">
    <div class="hero-compact">
      <div class="hero-topline">
        <div>
          <div class="eyebrow">한국 자산 관측소 · 부동산</div>
          <h1>서울/추적지역 대장 아파트 주간 스냅샷</h1>
        </div>
        <div class="hero-badges">
          <div class="lang-badge" id="re-updated">불러오는 중…</div>
          <div class="lang-badge">매주 토요일 갱신</div>
        </div>
      </div>
      <p class="hero-lead">
        서울 25개구와 추적지역의 <strong>가격 대장</strong>·<strong>거래량 대장</strong> 단지를 매주 한 표로 정리합니다.
        국토교통부 실거래가 기반, 최근 90일 거래 평균과 전고점·전세가율·직전 1년 흐름을 함께 봅니다.
      </p>
    </div>
  </section>

  <section class="container">
    <div class="mobile-hint" id="re-mobile-hint">📱 좌우로 스와이프하면 모든 컬럼을 볼 수 있습니다</div>
    <div class="re-frame">
      <div class="re-skeleton" id="re-skeleton">
        <div></div><div></div><div></div><div></div><div></div><div></div>
      </div>
      <iframe id="re-iframe" title="대장 아파트 주간 스냅샷" loading="lazy" hidden></iframe>
      <p class="re-empty" id="re-empty" hidden>
        아직 갱신된 스냅샷이 없습니다. 매주 토요일 오전에 갱신됩니다.
      </p>
      <p class="re-error" id="re-error" hidden>
        스냅샷을 불러오지 못했습니다. 잠시 후 다시 시도해주세요.
      </p>
    </div>
    <p class="re-foot">
      출처: 국토교통부 실거래가 공개시스템 기반 자체 가공 · 텔레그램 채널: <a href="https://t.me/mcpapt" target="_blank" rel="noopener">t.me/mcpapt</a>
    </p>
  </section>

  <script define:vars={{ apiBase }}>
    const HEIGHT_INJECT = `
<script>
(function(){
  function postHeight(){
    var h = Math.max(document.documentElement.scrollHeight, document.body.scrollHeight);
    parent.postMessage({ type: 're-height', height: h }, '*');
  }
  window.addEventListener('load', function(){
    postHeight();
    setTimeout(postHeight, 200);
  });
  window.addEventListener('resize', postHeight);
})();
<\/script>`;

    function formatUpdated(iso) {
      if (!iso) return '';
      try {
        const d = new Date(iso);
        if (Number.isNaN(d.getTime())) return '';
        const m = (d.getMonth() + 1).toString().padStart(2, '0');
        const day = d.getDate().toString().padStart(2, '0');
        const hh = d.getHours().toString().padStart(2, '0');
        const mm = d.getMinutes().toString().padStart(2, '0');
        return `갱신 ${m}-${day} ${hh}:${mm}`;
      } catch {
        return '';
      }
    }

    async function loadRealestate() {
      const skeleton = document.getElementById('re-skeleton');
      const iframe = document.getElementById('re-iframe');
      const empty = document.getElementById('re-empty');
      const error = document.getElementById('re-error');
      const updated = document.getElementById('re-updated');
      const hint = document.getElementById('re-mobile-hint');

      try {
        const url = (apiBase || '') + '/api/realestate-weekly';
        const res = await fetch(url, { headers: { Accept: 'application/json' } });
        if (!res.ok) throw new Error('HTTP ' + res.status);
        const data = await res.json();
        const html = (data.html || data.record?.html || '').toString();
        const updatedAt = (data.updatedAt || data.record?.updatedAt || '').toString();
        if (!html) {
          skeleton.hidden = true;
          empty.hidden = false;
          updated.textContent = '';
          if (hint) hint.style.display = 'none';
          return;
        }
        const withHeight = html.includes('</body>')
          ? html.replace('</body>', HEIGHT_INJECT + '</body>')
          : html + HEIGHT_INJECT;
        iframe.srcdoc = withHeight;
        iframe.hidden = false;
        skeleton.hidden = true;
        updated.textContent = formatUpdated(updatedAt);
      } catch (err) {
        skeleton.hidden = true;
        error.hidden = false;
        updated.textContent = '';
        if (hint) hint.style.display = 'none';
      }
    }

    window.addEventListener('message', (event) => {
      const data = event.data;
      if (!data || data.type !== 're-height' || typeof data.height !== 'number') return;
      const iframe = document.getElementById('re-iframe');
      if (!iframe) return;
      iframe.style.height = Math.max(400, Math.ceil(data.height) + 8) + 'px';
    });

    loadRealestate();
  </script>

  <style>
    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 1rem 3rem;
    }

    .hero-lead {
      margin: 0.85rem 0 0;
      color: rgba(255, 255, 255, 0.72);
      line-height: 1.7;
      font-size: 0.95rem;
    }

    .mobile-hint {
      display: none;
      margin: 0 0 0.5rem;
      padding: 0.55rem 0.85rem;
      background: rgba(120, 200, 255, 0.08);
      border: 1px solid rgba(120, 200, 255, 0.18);
      border-radius: 0.6rem;
      color: rgba(180, 220, 255, 0.9);
      font-size: 0.8rem;
      text-align: center;
    }

    @media (max-width: 768px) {
      .mobile-hint {
        display: block;
      }
    }

    .re-frame {
      position: relative;
      width: 100%;
      background: #eef3f8;
      border-radius: 0.8rem;
      /* 모바일에선 부모가 가로 스크롤. 데스크톱은 콘텐츠가 1180px 이하라 스크롤 안 생김. */
      overflow-x: auto;
      overflow-y: hidden;
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.18);
      min-height: 400px;
      -webkit-overflow-scrolling: touch;
    }

    .re-frame iframe {
      /* 콘텐츠 자체가 1138px 너비라 iframe도 동일 폭 고정.
         부모 .re-frame이 모바일에서 가로 스크롤을 담당. */
      width: 1180px;
      max-width: none;
      border: 0;
      display: block;
      background: #eef3f8;
    }

    .re-skeleton {
      display: flex;
      flex-direction: column;
      gap: 0.55rem;
      padding: 1.5rem;
    }
    .re-skeleton > div {
      height: 1rem;
      border-radius: 0.3rem;
      background: linear-gradient(90deg, rgba(0, 0, 0, 0.04), rgba(0, 0, 0, 0.1), rgba(0, 0, 0, 0.04));
      background-size: 200% 100%;
      animation: re-shimmer 1.5s ease-in-out infinite;
    }
    .re-skeleton > div:nth-child(2) { width: 88%; }
    .re-skeleton > div:nth-child(3) { width: 72%; }
    .re-skeleton > div:nth-child(4) { width: 80%; }
    .re-skeleton > div:nth-child(5) { width: 60%; }
    .re-skeleton > div:nth-child(6) { width: 92%; }

    @keyframes re-shimmer {
      0% { background-position: -100% 0; }
      100% { background-position: 100% 0; }
    }

    .re-empty,
    .re-error {
      margin: 0;
      padding: 2rem 1.5rem;
      color: #475569;
      text-align: center;
      font-size: 0.95rem;
    }
    .re-error { color: #b42318; }

    .re-foot {
      margin: 1rem 0 0;
      color: rgba(255, 255, 255, 0.6);
      font-size: 0.8rem;
      text-align: center;
    }
    .re-foot a {
      color: rgba(120, 200, 255, 0.85);
      text-decoration: none;
    }
    .re-foot a:hover {
      color: rgba(150, 220, 255, 1);
    }
  </style>
</BaseLayout>

---
import BaseLayout from '../components/BaseLayout.astro';
import { qvgmAsOf, qvgmKrTop, qvgmUsTop, qvgmWeights, type QvgmRecord } from '../data/qvgm';
import { sitePages } from '../data/site';
import { DEFAULT_SITE_URL } from '../lib/runtime';

const page = sitePages.find((item) => item.path === '/qvgm') ?? {
  title: 'QVGM+Moat 스크리너 | 김프보드',
  description: '저평가·퀄리티·성장·모멘텀·섹터·해자·병목을 결합한 LLM 보강 스크리너 결과',
  path: '/qvgm',
  locale: 'ko' as const,
};

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'QVGM+Moat 종목 스크리너',
  description: page.description,
  inLanguage: 'ko',
  url: `${DEFAULT_SITE_URL}${page.path}`,
  dateModified: qvgmAsOf,
};

const moatTypeLabel = (code: string): string => {
  const m: Record<string, string> = {
    BRAND: '브랜드',
    NETWORK: '네트워크 효과',
    COST: '원가 우위',
    IP: '지식재산',
    SWITCHING: '전환비용',
    REG: '규제/면허',
    NONE: '없음',
  };
  const c = (code || '').toUpperCase().trim();
  return m[c] || code || '';
};

const recBadge = (rec: string) => {
  const r = (rec || '').toUpperCase();
  if (r === 'STRONG_BUY') return { emoji: '🔥', label: '강력매수', cls: 'badge-strong' };
  if (r === 'BUY') return { emoji: '✅', label: '매수', cls: 'badge-buy' };
  if (r === 'HOLD') return { emoji: '🟨', label: '관망', cls: 'badge-hold' };
  if (r === 'AVOID') return { emoji: '⛔', label: '회피', cls: 'badge-avoid' };
  return { emoji: '•', label: rec || '-', cls: 'badge-default' };
};

const personaVerdictBadge = (verdict: string) => {
  const v = (verdict || '').toUpperCase();
  if (v === 'BUY') return { emoji: '✅', cls: 'badge-buy' };
  if (v === 'HOLD') return { emoji: '🟨', cls: 'badge-hold' };
  if (v === 'AVOID') return { emoji: '⛔', cls: 'badge-avoid' };
  return { emoji: '·', cls: 'badge-default' };
};

const PERSONAS: { key: 'buffett' | 'graham' | 'munger' | 'klarman'; label: string; tagline: string }[] = [
  { key: 'buffett', label: '워런 버핏', tagline: '강한 해자·예측 가능한 현금흐름' },
  { key: 'graham', label: '벤저민 그레이엄', tagline: '안전마진·자산가치 대비 저가' },
  { key: 'munger', label: '찰리 멍거', tagline: '사이클·경쟁 동학·역설적 사고' },
  { key: 'klarman', label: '세스 클라먼', tagline: '손실 회피·비대칭 보상' },
];

const fmt = {
  num1: (v: number | null | undefined) => (v == null ? '-' : v.toFixed(1)),
  pct: (v: number | null | undefined) => (v == null ? '-' : `${(v * 100).toFixed(1)}%`),
  pct0: (v: number | null | undefined) => (v == null ? '-' : `${(v * 100).toFixed(0)}%`),
  signed: (v: number | null | undefined) => (v == null ? '-' : `${(v * 100 >= 0 ? '+' : '')}${(v * 100).toFixed(0)}%`),
  score: (v: number | null | undefined) => (v == null ? '-' : v.toFixed(1)),
};

const sections = [
  { id: 'kr', title: '🇰🇷 한국 KOSPI/KOSDAQ TOP 10', records: qvgmKrTop, currency: 'KRW' },
  { id: 'us', title: '🇺🇸 미국 S&P 500 / MidCap 400 TOP 10', records: qvgmUsTop, currency: 'USD' },
];
---

<BaseLayout
  title={page.title}
  description={page.description}
  locale="ko"
  pathname={page.path}
  structuredData={structuredData}
>
  <section class="hero">
    <div class="hero-compact">
      <div class="hero-topline">
        <div>
          <div class="eyebrow">QVGM+Moat 스크리너</div>
          <h1>저평가·성장·해자·병목을 결합한 종목 발굴 리포트</h1>
          <p>
            한국 KOSPI/KOSDAQ 시총 상위 265종과 미국 S&amp;P 500 + MidCap 400 (903종)을 대상으로
            가치(Value), 품질(Quality), 성장(Growth), 모멘텀(Momentum), 섹터, 경제적 해자(Moat),
            공급 병목(Bottleneck) 7대 점수를 합산해 TOP 10을 추렸습니다.
            해자와 종목별 심층 코멘트는 <strong>Gemini 3.1 Pro</strong>가 생성했습니다.
          </p>
        </div>
        <div class="hero-badges">
          <div class="lang-badge">기준 {qvgmAsOf}</div>
          <div class="lang-badge">7대 점수 합산</div>
        </div>
      </div>
      <div class="metrics-grid">
        <article class="summary-card summary-card-primary">
          <strong>대상 시장</strong>
          <span>한국 + 미국</span>
          <p>KOSPI/KOSDAQ 265종 + S&amp;P 500/MidCap 400 903종</p>
        </article>
        <article class="summary-card summary-card-primary">
          <strong>경제적 해자 평가</strong>
          <span>Gemini 3.1 Pro</span>
          <p>브랜드 · 네트워크 · 원가 · 지식재산 · 전환비용 · 규제/면허 분류</p>
        </article>
        <article class="summary-card">
          <strong>가중치</strong>
          <span>V {Math.round(qvgmWeights.value * 100)}% · Moat {Math.round(qvgmWeights.moat * 100)}%</span>
          <p>
            Q {Math.round(qvgmWeights.quality * 100)}% · G {Math.round(qvgmWeights.growth * 100)}% ·
            M {Math.round(qvgmWeights.momentum * 100)}% · S {Math.round(qvgmWeights.sector * 100)}% ·
            병목 {Math.round(qvgmWeights.bottleneck * 100)}%
          </p>
        </article>
        <article class="summary-card summary-card-primary">
          <strong>🎩 4명 페르소나 합의 (신규)</strong>
          <span>버핏 · 그레이엄 · 멍거 · 클라먼</span>
          <p>
            전설적 투자자 4명이 종목별로 각자 철학에 따라 점수·찬반을 부여하고 합의 점수를 산출합니다.
            네 명의 시점이 같은 종목을 두고 토론·교차검증한 결과로 보시면 됩니다.
          </p>
        </article>
        <article class="summary-card">
          <strong>유의사항</strong>
          <span>참고용 리포트</span>
          <p>투자 권유가 아니며 매수 전 정성 검토를 병행해 주세요.</p>
        </article>
      </div>
    </div>
  </section>

  {sections.map((sec) => (
    <section class="qvgm-section">
      <h2>{sec.title}</h2>
      <div class="table-wrap">
        <table class="qvgm-table">
          <thead>
            <tr>
              <th>#</th>
              <th>티커</th>
              <th>종목</th>
              <th>총점</th>
              <th>경제적 해자</th>
              <th class="hide-sm">병목</th>
              <th class="hide-sm">PER</th>
              <th class="hide-sm">PBR</th>
              <th class="hide-md">ROE</th>
              <th class="hide-md">6m</th>
              <th>추천</th>
            </tr>
          </thead>
          <tbody>
            {sec.records.map((r: QvgmRecord) => {
              const b = recBadge(r.recommendation);
              return (
                <tr>
                  <td>{r.rank}</td>
                  <td class="mono">{r.ticker}</td>
                  <td class="td-name">{r.name}</td>
                  <td>{fmt.score(r.totalScore)}</td>
                  <td>{r.moatScore != null ? `${r.moatScore.toFixed(0)}${r.moatType ? ` (${moatTypeLabel(r.moatType)})` : ''}` : '-'}</td>
                  <td class="hide-sm">{r.bottleneck || '-'}</td>
                  <td class="hide-sm">{fmt.num1(r.metrics.per)}</td>
                  <td class="hide-sm">{fmt.num1(r.metrics.pbr)}</td>
                  <td class="hide-md">{fmt.pct0(r.metrics.roe)}</td>
                  <td class="hide-md">{fmt.signed(r.metrics.ret6m)}</td>
                  <td><span class={`badge ${b.cls}`}>{b.emoji} {b.label}</span></td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>

      <div class="cards-grid">
        {sec.records.map((r: QvgmRecord) => {
          const b = recBadge(r.recommendation);
          return (
            <article class="qvgm-card">
              <header>
                <span class={`badge ${b.cls}`}>{b.emoji} {b.label}{r.conviction != null ? ` · ${r.conviction.toFixed(0)}` : ''}</span>
                <strong>{r.name}</strong>
                <span class="mono">{r.ticker}</span>
              </header>
              <p class="one-liner">{r.oneLiner}</p>
              <dl>
                <div><dt>섹터</dt><dd>{r.sector || '-'}{r.bottleneck ? ` · 병목: ${r.bottleneck}` : ''}</dd></div>
                <div><dt>핵심사업</dt><dd>{r.coreBusiness || '-'}</dd></div>
                <div><dt>경쟁우위</dt><dd>{r.competitiveEdge || '-'}</dd></div>
                <div><dt>촉매</dt><dd>{r.catalysts.length ? r.catalysts.join(' · ') : '-'}</dd></div>
                <div><dt>리스크</dt><dd>{r.risks.length ? r.risks.join(' · ') : '-'}</dd></div>
                <div><dt>밸류에이션</dt><dd>{r.valuationNote || '-'}</dd></div>
              </dl>
              <footer>
                {r.metrics.per != null && <span>PER {fmt.num1(r.metrics.per)}</span>}
                {r.metrics.pbr != null && <span>PBR {fmt.num1(r.metrics.pbr)}</span>}
                {r.metrics.psr != null && <span>PSR {fmt.num1(r.metrics.psr)}</span>}
                {r.metrics.roe != null && <span>ROE {fmt.pct0(r.metrics.roe)}</span>}
                {r.metrics.fcfYield != null && <span>FCFy {fmt.pct(r.metrics.fcfYield)}</span>}
                {r.metrics.ret6m != null && <span>6m {fmt.signed(r.metrics.ret6m)}</span>}
                {r.metrics.ret12m != null && <span>12m {fmt.signed(r.metrics.ret12m)}</span>}
                {r.moatScore != null && <span>경제적 해자 {r.moatScore.toFixed(0)} ({moatTypeLabel(r.moatType)})</span>}
              </footer>

              {r.personas && (
                <div class="persona-block">
                  <div class="persona-header">
                    <span class="persona-title">🎩 4명 페르소나 토론 결과</span>
                    {r.personas.consensus != null && (
                      <span class="persona-consensus">합의 {Math.round(r.personas.consensus)}</span>
                    )}
                  </div>
                  {r.personas.summary && (
                    <p class="persona-summary">버핏·그레이엄·멍거·클라먼이 함께 검토한 결과: {r.personas.summary}</p>
                  )}
                  <ul class="persona-list">
                    {PERSONAS.map(({ key, label, tagline }) => {
                      const p = r.personas?.[key];
                      const b = personaVerdictBadge(p?.verdict || '');
                      return (
                        <li class="persona-row">
                          <div class="persona-name">
                            <strong>{label}</strong>
                            <span class="persona-tagline">{tagline}</span>
                          </div>
                          <div class="persona-verdict">
                            <span class={`badge persona-badge ${b.cls}`}>
                              {b.emoji} {p?.score != null ? Math.round(p.score) : '-'}
                            </span>
                            {p?.note && <span class="persona-note">{p.note}</span>}
                          </div>
                        </li>
                      );
                    })}
                  </ul>
                </div>
              )}
            </article>
          );
        })}
      </div>
    </section>
  ))}

  <section class="disclaimer">
    <h3>방법론 요약</h3>
    <ul>
      <li>유니버스: KOSPI/KOSDAQ 시총 상위 265종 (Naver Finance) · S&amp;P 500 + MidCap 400 (Wikipedia)</li>
      <li>데이터: yahooquery 일괄 + KR 상위 60종 DART 정밀화 (ROIC·매출·영업이익)</li>
      <li>점수: Value 16% · Quality 12% · Growth 15% · Momentum 13% · Sector 12% · Moat 17% · 병목 5% · 페르소나 10%</li>
      <li>경제적 해자: Gemini 3.1 Pro로 0~100 점수 + 브랜드/네트워크/원가/지식재산/전환비용/규제·면허 분류</li>
      <li>병목: 반도체 HBM·전력기기·방산·조선·원전·희토류·광케이블 등 공급제약 테마 매칭</li>
      <li>심층 카드: Gemini 3.1 Pro로 핵심사업·경쟁우위·촉매·리스크·밸류·추천강도 생성</li>
      <li>
        🎩 페르소나 합의: 워런 버핏 · 벤저민 그레이엄 · 찰리 멍거 · 세스 클라먼 4명이 자신의 투자 철학에 따라
        같은 종목을 0~100점·BUY/HOLD/AVOID로 평가하고, 평균을 합의 점수로 산출합니다.
        합의 점수는 총점에 10% 가중치로 가산되어 TOP 10 내부 순위 결정에 반영됩니다 (룰 점수 90% + 페르소나 10%).
        단일 모델의 평면적 의견이 아니라 서로 다른 시점이 토론·교차검증한 결과로 활용해 주세요.
      </li>
    </ul>
    <p class="warn">
      ※ 본 페이지는 1차 발굴 + 정성 보강 자동화 결과입니다. 실제 매수·매도 의사결정은 본인의 추가 검토에 따라 주세요.
    </p>
  </section>

  <style>
    .qvgm-section { margin: 2rem 0; }
    .qvgm-section h2 { margin-bottom: 0.75rem; font-size: 1.3rem; }

    /* hero summary-card 내부 긴 한글 라벨이 좁은 카드 폭을 넘지 않도록.
       word-break: keep-all 로 단어 중간 분절 방지, '·' 주변 공백에서 자연스럽게 wrap. */
    .hero .metrics-grid .summary-card p,
    .hero .metrics-grid .summary-card span {
      word-break: keep-all;
      overflow-wrap: anywhere;
    }

    .table-wrap {
      overflow-x: auto;
      border: 1px solid rgba(148, 163, 184, 0.25);
      border-radius: 10px;
      margin-bottom: 1.25rem;
      -webkit-overflow-scrolling: touch;
    }
    .qvgm-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
    .qvgm-table thead { background: #1F4E78; color: white; position: sticky; top: 0; }
    .qvgm-table th, .qvgm-table td {
      padding: 10px 12px;
      text-align: center;
      border-bottom: 1px solid rgba(148, 163, 184, 0.18);
      vertical-align: middle;
    }
    .qvgm-table .td-name { text-align: left; font-weight: 500; }
    /* 반투명 alt-row → 라이트/다크 모두에서 텍스트 가독성 보장 */
    .qvgm-table tbody tr:nth-child(even) { background: rgba(148, 163, 184, 0.10); }
    .qvgm-table tbody tr:hover { background: rgba(59, 130, 246, 0.10); }
    .qvgm-table .mono { font-family: ui-monospace, SFMono-Regular, monospace; }

    .badge {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 999px;
      font-size: 0.78rem;
      font-weight: 700;
      white-space: nowrap;
    }
    .badge-strong { background: #fee2e2; color: #b91c1c; }
    .badge-buy { background: #dcfce7; color: #166534; }
    .badge-hold { background: #fef3c7; color: #92400e; }
    .badge-avoid { background: #e0e7ff; color: #3730a3; }
    .badge-default { background: #f1f5f9; color: #475569; }

    .cards-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(min(100%, 360px), 1fr));
      gap: 1rem;
      margin-top: 1rem;
    }
    .qvgm-card {
      background: white;
      border: 1px solid rgba(148, 163, 184, 0.30);
      border-radius: 14px;
      padding: 1.1rem 1rem;
      box-shadow: 0 2px 6px rgba(15, 23, 42, 0.06);
    }
    .qvgm-card header { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 0.4rem; }
    .qvgm-card header strong { font-size: 1.05rem; }
    .qvgm-card .one-liner { font-style: italic; color: #334155; margin: 0.4rem 0 0.8rem; line-height: 1.45; }
    .qvgm-card dl { margin: 0; }
    .qvgm-card dl > div {
      display: grid;
      grid-template-columns: 5.5rem 1fr;
      gap: 0.5rem;
      padding: 0.4rem 0;
      border-bottom: 1px dashed rgba(148, 163, 184, 0.25);
    }
    .qvgm-card dt { color: #64748b; font-size: 0.8rem; font-weight: 700; }
    .qvgm-card dd { margin: 0; font-size: 0.92rem; color: #1e293b; line-height: 1.5; }
    .qvgm-card footer {
      margin-top: 0.7rem;
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
      font-size: 0.78rem;
      color: #475569;
    }
    .qvgm-card footer span { background: rgba(148, 163, 184, 0.18); padding: 3px 9px; border-radius: 6px; }

    .persona-block {
      margin-top: 0.9rem;
      padding: 0.8rem 0.9rem;
      background: rgba(99, 102, 241, 0.08);
      border: 1px solid rgba(99, 102, 241, 0.25);
      border-radius: 10px;
    }
    .persona-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 0.35rem;
    }
    .persona-title { font-size: 0.85rem; font-weight: 700; color: #4338ca; }
    .persona-consensus {
      font-size: 0.78rem;
      font-weight: 700;
      background: #4338ca;
      color: white;
      padding: 3px 10px;
      border-radius: 999px;
    }
    .persona-summary {
      margin: 0 0 0.5rem;
      font-size: 0.85rem;
      color: #1e293b;
      line-height: 1.5;
      font-style: italic;
    }
    .persona-list { list-style: none; margin: 0; padding: 0; }
    .persona-row {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 0.5rem;
      padding: 0.45rem 0;
      border-top: 1px dashed rgba(99, 102, 241, 0.18);
      align-items: start;
    }
    .persona-row:first-child { border-top: none; }
    .persona-name { display: flex; flex-direction: column; gap: 0.1rem; }
    .persona-name strong { font-size: 0.88rem; color: #1e1b4b; }
    .persona-tagline { font-size: 0.72rem; color: #64748b; }
    .persona-verdict { display: flex; flex-direction: column; align-items: flex-end; gap: 0.25rem; max-width: 60%; text-align: right; }
    .persona-badge { font-size: 0.78rem; padding: 2px 9px; }
    .persona-note {
      font-size: 0.78rem;
      color: #334155;
      line-height: 1.45;
      max-width: 100%;
      word-break: keep-all;
      overflow-wrap: anywhere;
    }

    @media (prefers-color-scheme: dark) {
      .persona-block {
        background: rgba(99, 102, 241, 0.10);
        border-color: rgba(99, 102, 241, 0.35);
      }
      .persona-title { color: #c7d2fe; }
      .persona-summary { color: #cbd5e1; }
      .persona-name strong { color: #e0e7ff; }
      .persona-tagline { color: #94a3b8; }
      .persona-note { color: #cbd5e1; }
    }

    .disclaimer {
      margin-top: 2rem;
      padding: 1.1rem 1.25rem;
      background: rgba(148, 163, 184, 0.10);
      border: 1px solid rgba(148, 163, 184, 0.30);
      border-radius: 12px;
      font-size: 0.9rem;
    }
    .disclaimer h3 { margin-top: 0; }
    .disclaimer ul { padding-left: 1.2rem; }
    .disclaimer .warn { color: #b91c1c; font-weight: 700; margin-top: 0.5rem; }

    /* 모바일: 일부 컬럼 숨김 → 가독성 우선 */
    @media (max-width: 768px) {
      .qvgm-table { font-size: 0.82rem; }

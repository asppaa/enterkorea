---
import BaseLayout from '../../components/BaseLayout.astro';
import { getCollection } from 'astro:content';

const page = {
  title: '일지 | 김프보드 운영자의 주간 매매·시장 일지',
  description:
    '김프보드 데이터와 함께 운영자의 주간 매매·시장 해석·교훈을 정리하는 일지. 1인칭, 비중 단위, 실패까지 함께 공개.',
  path: '/journal',
  locale: 'ko' as const,
};

const allPosts = await getCollection('journal', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => (a.data.date < b.data.date ? 1 : -1));

const formatDate = (iso: string) => {
  const dt = new Date(iso);
  return `${dt.getFullYear()}-${String(dt.getMonth() + 1).padStart(2, '0')}-${String(dt.getDate()).padStart(2, '0')}`;
};
---

<BaseLayout title={page.title} description={page.description} locale="ko" pathname={page.path}>
  <section class="hero">
    <div class="eyebrow">일지</div>
    <h1 class="page-title">운영자의 주간 매매·시장 일지</h1>
    <p class="lede">
      매주 일요일 한 주의 매매·시장 해석·다음 주 watch list 를 정리합니다. 모든 글은 1인칭이며, 추천이 아닌 본인 기록입니다.
      비중은 % 단위로만 공개하고, 실패한 거래도 같이 기록합니다.
    </p>
  </section>

  {posts.length === 0 ? (
    <section class="section copy-panel">
      <p>아직 발행된 글이 없습니다.</p>
    </section>
  ) : (
    <section class="section">
      <ul class="journal-list">
        {posts.map((post) => (
          <li>
            <a href={`/journal/${post.id}`}>
              <div class="meta">
                <time datetime={post.data.date}>{formatDate(post.data.date)}</time>
                {post.data.tags.length > 0 && (
                  <span class="tags">{post.data.tags.map((t) => `#${t}`).join(' ')}</span>
                )}
              </div>
              <h2>{post.data.title}</h2>
              <p>{post.data.summary}</p>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <section class="section copy-panel">
    <h2>이 일지가 따르는 원칙</h2>
    <ul class="bullet-list">
      <li>모든 글은 1인칭. 어떤 권유 문구도 사용하지 않습니다.</li>
      <li>실패한 매매도 그대로 기록합니다.</li>
      <li>보유 자산은 비중(%) 단위로만 공개합니다.</li>
      <li>주장에는 김프보드 데이터·QVGM 결과·매크로 지표 같은 검증 가능한 근거를 답니다.</li>
    </ul>
    <p>
      <small>본 일지의 어떤 내용도 투자 권유가 아닙니다. <a href="/disclaimer">면책조항</a> 참고.</small>
    </p>
  </section>

  <style>
    .journal-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 12px; }
    .journal-list li { margin: 0; padding: 0; }
    .journal-list a {
      display: block;
      padding: 18px 20px;
      border-radius: 14px;
      border: 1px solid var(--line, rgba(148, 163, 184, 0.18));
      background: rgba(15, 25, 43, 0.55);
      transition: border-color 140ms ease, background 140ms ease;
    }
    .journal-list a:hover {
      border-color: var(--accent, #8fdcff);
      background: rgba(143, 220, 255, 0.06);
    }
    .journal-list .meta {
      display: flex;
      gap: 12px;
      font-size: 0.78rem;
      color: var(--muted);
      margin-bottom: 6px;
    }
    .journal-list .tags { color: var(--accent, #8fdcff); }
    .journal-list h2 {
      margin: 0 0 6px;
      font-size: 1.15rem;
      color: var(--text);
    }
    .journal-list p { margin: 0; color: var(--muted); font-size: 0.92rem; line-height: 1.55; }
  </style>
</BaseLayout>

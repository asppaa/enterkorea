---
import BaseLayout from '../../components/BaseLayout.astro';
import { compareSnapshots } from '../../data/market';
import { sitePages } from '../../data/site';
import { formatPercent } from '../../lib/format';

const page = sitePages.find((item) => item.path === '/en/upbit-vs-binance')!;
const data = compareSnapshots['upbit-binance'];
---

<BaseLayout
  title={page.title}
  description={page.description}
  locale="en"
  pathname={page.path}
  alternates={[
    { lang: 'en', path: '/en/upbit-vs-binance' },
    { lang: 'ko', path: '/compare/upbit-binance' },
  ]}
>
  <section class="hero">
    <div class="eyebrow">Reserved English path</div>
    <h1>Upbit vs Binance</h1>
    <p>A lightweight English landing page for future expansion into spread and Korean market context queries.</p>
  </section>

  <section class="section panel">
    <table class="coin-table">
      <thead>
        <tr>
          <th>Coin</th>
          <th>Spread</th>
          <th>Percent</th>
        </tr>
      </thead>
      <tbody>
        {
          data.rows.map((row) => (
            <tr>
              <td>{row.symbol}</td>
              <td>{row.spreadKrw}</td>
              <td class={row.spreadPercent >= 0 ? 'positive' : 'negative'}>{formatPercent(row.spreadPercent)}</td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </section>
</BaseLayout>

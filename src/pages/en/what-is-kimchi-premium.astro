---
import BaseLayout from '../../components/BaseLayout.astro';
import { sitePages } from '../../data/site';

const page = sitePages.find((item) => item.path === '/en/what-is-kimchi-premium')!;
---

<BaseLayout
  title={page.title}
  description={page.description}
  locale="en"
  pathname={page.path}
  alternates={[
    { lang: 'en', path: '/en/what-is-kimchi-premium' },
    { lang: 'ko', path: '/guide/김치프리미엄-뜻' },
  ]}
>
  <section class="hero">
    <div class="eyebrow">Reserved English guide</div>
    <h1>What Is Kimchi Premium?</h1>
    <p>
      The kimchi premium describes the gap between Korean market prices and global benchmarks. In this project, that idea becomes the starting point for a broader Korea premium observatory.
    </p>
  </section>

  <section class="section copy-panel">
    <h2>Why this route exists</h2>
    <p>
      English demand for the term exists, but it is still niche. The product therefore launches with Korean demand first while keeping clean English routes ready for later expansion.
    </p>
  </section>
</BaseLayout>

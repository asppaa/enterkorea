---
import BaseLayout from '../../components/BaseLayout.astro';
import { guideSnippets } from '../../data/market';
import { sitePages } from '../../data/site';

const page = sitePages.find((item) => item.path === '/guide/김프-보는법')!;
---

<BaseLayout title={page.title} description={page.description} locale="ko" pathname={page.path}>
  <section class="hero">
    <div class="eyebrow">기본 가이드</div>
    <h1>김프 보는 법</h1>
    <p>김프 수치만 따로 보지 않고, 거래대금과 국내 거래소 차이, ETF 괴리율처럼 같은 프레임의 데이터까지 함께 읽는 기본 루틴을 정리합니다.</p>
  </section>

  <section class="section copy-panel">
    <h2>읽는 순서</h2>
    {guideSnippets.howToRead.map((paragraph) => <p>{paragraph}</p>)}
  </section>
</BaseLayout>

---
import BaseLayout from '../../components/BaseLayout.astro';
import { guideSnippets } from '../../data/market';
import { sitePages } from '../../data/site';

const page = sitePages.find((item) => item.path === '/guide/역프-뜻')!;
---

<BaseLayout title={page.title} description={page.description} locale="ko" pathname={page.path}>
  <section class="hero">
    <div class="eyebrow">기본 가이드</div>
    <h1>역프 뜻</h1>
    <p>한국시장 가격이 해외 기준이나 NAV보다 낮아지는 역프가 코인, ETF, 원자재에서 각각 어떻게 보이는지 같은 관점으로 정리합니다.</p>
  </section>

  <section class="section copy-panel">
    <h2>역프를 볼 때 체크할 것</h2>
    {guideSnippets.reversePremium.map((paragraph) => <p>{paragraph}</p>)}
  </section>
</BaseLayout>

---
import BaseLayout from '../../components/BaseLayout.astro';
import { guideSnippets } from '../../data/market';
import { sitePages } from '../../data/site';

const page = sitePages.find((item) => item.path === '/guide/김치프리미엄-뜻')!;
const faq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: '김프가 플러스면 무슨 뜻인가요?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '한국 가격이 해외 기준보다 더 비싼 상태라는 뜻입니다.',
      },
    },
    {
      '@type': 'Question',
      name: '마이너스면 한국 시장이 더 싼 건가요?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '네. 역프 상태로 보고, 한국 시장이 글로벌 기준보다 더 약하다고 해석할 수 있습니다.',
      },
    },
  ],
};
---

<BaseLayout
  title={page.title}
  description={page.description}
  locale="ko"
  pathname={page.path}
  alternates={[
    { lang: 'ko', path: '/guide/김치프리미엄-뜻' },
    { lang: 'en', path: '/en/what-is-kimchi-premium' },
  ]}
  structuredData={faq}
>
  <section class="hero">
    <div class="eyebrow">기본 가이드</div>
    <h1>김치프리미엄 뜻</h1>
    <p>김프보드가 왜 코인 김프에서 출발해 ETF 괴리율과 원자재 프리미엄까지 확장하는지 이해할 수 있도록, 김치프리미엄의 핵심 개념을 먼저 정리합니다.</p>
  </section>

  <section class="section copy-panel">
    <h2>핵심 설명</h2>
    {guideSnippets.kimchiDefinition.map((paragraph) => <p>{paragraph}</p>)}
  </section>
</BaseLayout>

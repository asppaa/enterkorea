---
import BaseLayout from '../../components/BaseLayout.astro';
import { sitePages } from '../../data/site';

const page = sitePages.find((item) => item.path === '/guide/김프-차익거래-비용')!;
const faq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: '김프 1%가 보이면 1% 이익을 얻을 수 있나요?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '거의 그렇지 않습니다. 매수·매도 수수료, 출금 수수료, 환전 스프레드, 송금 지연 동안의 가격 변동을 합치면 표면 김프의 절반 이상이 비용으로 사라지는 경우가 일반적입니다.',
      },
    },
    {
      '@type': 'Question',
      name: '한 사이클에 보통 몇 시간이 걸리나요?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '거래소 간 입출금 점검·트래블룰 확인 시간을 더하면 빠르면 30분, 늦으면 6~12시간이 걸리며, 이 시간만큼 가격 변동 위험에 노출됩니다.',
      },
    },
  ],
};
---

<BaseLayout title={page.title} description={page.description} locale="ko" pathname={page.path} structuredData={faq}>
  <section class="hero">
    <div class="eyebrow">기본 가이드</div>
    <h1>김프 차익거래의 실제 비용</h1>
    <p>화면에 보이는 김프 수치가 그대로 수익이 되지 않는 이유를, 한 사이클에 발생하는 모든 비용을 단계별로 분해해 정리합니다.</p>
  </section>

  <section class="section copy-panel">
    <h2>한 사이클은 무엇으로 구성되는가</h2>
    <p>김프 차익거래는 보통 다음 단계를 거칩니다. 단계마다 비용·시간·실패 가능성이 모두 따로 발생하며, 김프 수치는 이 모든 비용을 합산해야 비로소 실수익을 보여줍니다.</p>
    <ul class="bullet-list">
      <li>① 해외 거래소에서 코인을 USDT 또는 USD로 매수</li>
      <li>② 한국 거래소로 코인을 송금(또는 USDT를 송금 후 매수)</li>
      <li>③ 한국 거래소에서 코인을 매도하고 원화로 전환</li>
      <li>④ 원화를 은행 계좌로 출금</li>
      <li>⑤ 다시 해외 거래소로 외화를 환전·송금해 자본을 복귀시킴</li>
    </ul>
  </section>

  <section class="section copy-panel">
    <h2>각 단계의 평균 비용</h2>
    <ul class="bullet-list">
      <li><strong>해외 매수 수수료</strong> — 0.05% ~ 0.20%. 거래소·결제 수단에 따라 다르며, 메이커·테이커 구분으로 차이가 납니다.</li>
      <li><strong>출금 네트워크 수수료</strong> — 0.0005 BTC, 5 USDT(TRC20), 0.005 ETH 등 정액. 작은 수량을 보낼수록 비율이 커집니다.</li>
      <li><strong>한국 매도 수수료</strong> — 0.04% ~ 0.25%. 업비트는 보통 0.04~0.05%, 빗썸은 쿠폰 적용 후 0.04% 수준이지만 적용 조건을 잘 봐야 합니다.</li>
      <li><strong>원화 출금 수수료</strong> — 1,000원 안팎. 큰 자본 회전에선 비중이 작지만 소액 회전에선 무시할 수 없습니다.</li>
      <li><strong>환전 스프레드</strong> — 은행 매도·매수 환율 차이 약 1.0% ~ 1.7%. 환전 우대 적용 시 0.3~0.5%까지 줄일 수 있습니다.</li>
      <li><strong>해외 송금 수수료</strong> — 송금 은행·중계 은행에 따라 1만~3만원 안팎의 정액 또는 0.1% 이내의 수수료가 발생합니다.</li>
    </ul>
    <p>위 비용을 모두 합치면 한 사이클당 0.7% ~ 1.8% 수준이 되는 것이 보통이고, 김프 1%가 보이는 상황에서는 실제로 거의 손익분기점에서 벗어나기 어렵습니다.</p>
  </section>

  <section class="section copy-panel">
    <h2>가격 변동 위험을 빼먹으면 안 됩니다</h2>
    <p>비용 외에 시간 위험이 있습니다. 코인 송금이 한국 거래소에 도착할 때까지 짧으면 10분, 길면 수 시간이 걸립니다. 이 시간 동안 가격이 1~2% 변동하는 일은 코인 시장에서 흔하기 때문에, 표시 김프가 도착 시점에는 사라져 있을 수 있습니다. 이 위험은 사이클 자본 규모에 비례해 커지므로 큰 자본일수록 분할·분산 사이클이 필요합니다.</p>
  </section>

  <section class="section copy-panel">
    <h2>실패·지연 시 비용</h2>
    <ul class="bullet-list">
      <li>트래블룰 미준수로 입금 보류 → 본인확인까지 24~72시간</li>
      <li>거래소 입출금 임시 점검 → 사이클 중단 후 가격 변동 위험 누적</li>
      <li>은행 외환 신고 누락 → 향후 외환 거래 제약</li>
      <li>잘못된 네트워크로 출금 → 자산 유실 가능</li>
    </ul>
  </section>

  <section class="section copy-panel">
    <h2>김프보드의 권장 사용법</h2>
    <p>김프 수치는 거래 신호가 아니라 한국 시장의 가격 왜곡을 측정하는 지표로 활용하시기를 권합니다. 같은 시점의 BTC·ETH·USDT 김프, 국내 거래소 차이, 환율, Fear & Greed Index, ETF 괴리율을 함께 비교하면 단기 시장 흐름을 더 정확히 읽을 수 있습니다. 실제 차익거래는 위 비용을 자기 자본·은행·거래소 환경에 맞춰 직접 시뮬레이션한 뒤에 결정하시기 바랍니다.</p>
  </section>

  <section class="section copy-panel">
    <h2>관련 페이지</h2>
    <ul class="bullet-list">
      <li><a href="/guide/USDT-김프">USDT 김프</a></li>
      <li><a href="/guide/트래블룰">트래블룰</a></li>
      <li><a href="/guide/김프-보는법">김프 보는 법</a></li>
      <li><a href="/disclaimer">면책조항</a></li>
    </ul>
  </section>
</BaseLayout>

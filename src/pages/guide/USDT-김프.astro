---
import BaseLayout from '../../components/BaseLayout.astro';
import { sitePages } from '../../data/site';

const page = sitePages.find((item) => item.path === '/guide/USDT-김프')!;
const faq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'USDT 김프와 BTC 김프는 왜 다르게 움직이나요?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'USDT는 가격 변동이 거의 없는 스테이블코인이므로 김프가 곧 한국 시장의 달러 수요·공급 불균형을 반영합니다. BTC 김프는 위험자산 수요까지 섞이기 때문에 두 김프가 따로 움직이는 일이 흔합니다.',
      },
    },
    {
      '@type': 'Question',
      name: 'USDT 김프가 양(+)이면 어떻게 해석하나요?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '한국 거래소에서 USDT가 1달러보다 비싸게 거래된다는 뜻이며, 일반적으로 한국 시장 참여자가 코인 매수를 위해 달러 표시 자산을 구매하려는 압력이 강하다고 해석합니다.',
      },
    },
    {
      '@type': 'Question',
      name: 'USDT 김프 차익거래는 가능합니까?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '이론적으로는 가능하지만 실제로는 트래블룰, 출금 한도, 환전 비용, 송금 지연 때문에 표면 김프보다 실수익이 훨씬 작거나 마이너스가 되는 경우가 많습니다.',
      },
    },
  ],
};
---

<BaseLayout title={page.title} description={page.description} locale="ko" pathname={page.path} structuredData={faq}>
  <section class="hero">
    <div class="eyebrow">기본 가이드</div>
    <h1>USDT 김프란 무엇인가</h1>
    <p>스테이블코인 김프는 코인 시장의 위험선호와 환율 수급을 분리해 보여주는 핵심 지표입니다. USDT 김프가 BTC·ETH 김프와 어떻게 다르고, 어떻게 읽어야 하는지 정리합니다.</p>
  </section>

  <section class="section copy-panel">
    <h2>USDT 김프의 정의</h2>
    <p>USDT 김프는 한국 거래소(주로 빗썸)에서 거래되는 USDT의 원화 가격을 1달러 가치(환율 기준)에 견준 차이입니다. USDT는 발행사가 1USDT = 1USD의 안정 가치를 유지하도록 설계한 스테이블코인이므로, 이론상 환율(USD/KRW)에 가까운 가격에 거래되어야 합니다. 그러나 한국 시장의 달러 수요가 강해지면 USDT 가격이 환율보다 비싸게 형성되며 이 차이가 USDT 김프로 측정됩니다.</p>
  </section>

  <section class="section copy-panel">
    <h2>BTC·ETH 김프와의 결정적 차이</h2>
    <p>비트코인 김프는 두 가지 요소가 섞여 있습니다. 하나는 한국 시장의 달러 수급(환율 김프), 다른 하나는 한국 시장의 위험자산 선호도(코인 자체 김프)입니다. USDT는 가격 변동이 거의 없으므로 두 번째 요소가 빠지고, 첫 번째 요소만 남습니다. 그래서 USDT 김프와 BTC 김프의 차이는 곧 "코인 자체 김프"의 추정치로 활용됩니다.</p>
    <ul class="bullet-list">
      <li>USDT 김프 ≈ 한국 시장의 달러 김프</li>
      <li>BTC 김프 − USDT 김프 ≈ 한국 시장의 위험자산 추가 김프</li>
      <li>두 김프가 같은 방향이면 환율·위험선호가 동시에 작용 중</li>
      <li>두 김프가 반대 방향이면 한쪽 요인이 지배적</li>
    </ul>
  </section>

  <section class="section copy-panel">
    <h2>USDT 김프가 벌어지는 전형적인 시나리오</h2>
    <ul class="bullet-list">
      <li><strong>해외 거래소 매수 수요 증가</strong> — 한국 투자자가 해외 거래소에서 알트코인이나 선물을 매매하기 위해 USDT를 사들일 때.</li>
      <li><strong>환율 급등기</strong> — 원·달러 환율이 빠르게 오르면 환전 한도와 송금 절차의 시차로 USDT 가격이 환율 변동을 먼저 흡수합니다.</li>
      <li><strong>국내 시장의 위험회피 전환</strong> — 코인 매도 후 일시적으로 USDT로 전환하는 수요가 늘면 단기 김프가 발생할 수 있습니다.</li>
    </ul>
  </section>

  <section class="section copy-panel">
    <h2>USDT 김프 차익거래의 실제 비용</h2>
    <p>USDT 김프가 1% 이상 벌어지면 표면적으로 매력적인 차익으로 보이지만, 다음 비용을 모두 합치면 사이클 한 번에 0.5~1.5% 가량의 비용이 발생하는 것이 일반적입니다.</p>
    <ul class="bullet-list">
      <li>해외 거래소 USDT 매수 수수료(0.05~0.2%)</li>
      <li>USDT 출금 네트워크 수수료(TRC20·ERC20에 따라 정액)</li>
      <li>한국 거래소 USDT 입금 후 매도 수수료(0.04~0.25%)</li>
      <li>원화 출금 수수료, 은행 환전 스프레드</li>
      <li>송금 지연 동안의 환율·USDT 시세 변동 위험</li>
    </ul>
    <p>특히 트래블룰 적용으로 거래소 간 USDT 송금이 즉시 처리되지 않는 경우가 많아, "표시 김프 그대로 받는다"는 가정은 거의 성립하지 않습니다. 김프보드는 USDT 김프를 차익거래 권유가 아니라 한국 시장의 달러 수급 신호로 활용하시길 권합니다.</p>
  </section>

  <section class="section copy-panel">
    <h2>관련 페이지</h2>
    <ul class="bullet-list">
      <li><a href="/guide/김치프리미엄-뜻">김치프리미엄 뜻</a></li>
      <li><a href="/guide/트래블룰">트래블룰</a></li>
      <li><a href="/guide/김프-차익거래-비용">김프 차익거래의 실제 비용</a></li>
      <li><a href="/risk">위험 신호 보드</a></li>
    </ul>
  </section>
</BaseLayout>

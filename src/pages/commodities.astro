---
import BaseLayout from '../components/BaseLayout.astro';
import AdSlot from '../components/AdSlot.astro';
import TelegramInvite from '../components/TelegramInvite.astro';
import { commoditySnapshots, marketMeta } from '../data/market';
import { sitePages } from '../data/site';
import { formatKrw, formatPercent, formatUsd } from '../lib/format';

const page = sitePages.find((item) => item.path === '/commodities')!;
const apiBase = import.meta.env.PUBLIC_KIMP_API_BASE || (import.meta.env.DEV ? 'http://127.0.0.1:8787' : '');
const lead = [...commoditySnapshots].sort((left, right) => Math.abs(right.deviationPercent) - Math.abs(left.deviationPercent))[0];
---

<BaseLayout title={page.title} description={page.description} locale="ko" pathname={page.path}>
  <section class="hero">
    <div class="hero-compact">
      <div class="hero-topline">
        <div>
          <div class="eyebrow">한국 프리미엄 관측소 · 원자재</div>
          <h1>금 · 은 · 구리 · 원유 국내 괴리율</h1>
        </div>
        <div class="hero-badges">
          <div class="lang-badge" id="commodity-live-status">{apiBase ? '실시간 연결 대기 중' : `스냅샷 · ${marketMeta.updatedAt}`}</div>
          <div class="lang-badge">{marketMeta.cacheWindowSeconds}초 갱신</div>
        </div>
      </div>
      <div class="summary-grid">
        <article class="summary-card summary-card-primary">
          <strong>대표 원자재 괴리</strong>
          <span id="commodity-lead" class={lead.deviationPercent >= 0 ? 'positive' : 'negative'}>
            {lead.name} {formatPercent(lead.deviationPercent)}
          </span>
          <p>절대값 기준 최대 괴리</p>
        </article>
        <article class="summary-card">
          <strong>벤치마크 예시</strong>
          <span>GLD · SLV · CPER</span>
          <p>해외 원자재 ETF를 보조 참조</p>
        </article>
        <article class="summary-card">
          <strong>읽는 법</strong>
          <span>국내 ETF vs NAV</span>
          <p>한국 수급이 강한 상품은 괴리율이 크게 벌어집니다</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <article class="panel">
      <div class="section-header">
        <div>
          <h2>원자재 실시간 보드</h2>
          <p>국내 ETF 시장가와 NAV 괴리, 거래대금, 해외 기준값을 한 표로 봅니다.</p>
        </div>
      </div>
      <div class="table-scroll">
        <table class="asset-table">
          <thead>
            <tr>
              <th>종목</th>
              <th>시장가</th>
              <th>NAV</th>
              <th>괴리율</th>
              <th>거래대금</th>
              <th>해외 기준</th>
            </tr>
          </thead>
          <tbody id="commodity-body">
            {
              commoditySnapshots.map((item) => (
                <tr>
                  <td>
                    <strong>{item.name}</strong>
                    <div class="tiny">{item.code} · {item.category}</div>
                  </td>
                  <td>{formatKrw(item.marketPriceKrw)}</td>
                  <td>{formatKrw(item.navKrw)}</td>
                  <td class={item.deviationPercent >= 0 ? 'positive' : 'negative'}>{formatPercent(item.deviationPercent)}</td>
                  <td>{formatKrw(item.volumeKrw)}</td>
                  <td>{item.benchmarkSymbol.replace('.US', '')} · {formatUsd(item.benchmarkPrice)}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </article>
  </section>

  <section class="section">
    <TelegramInvite compact title="원자재 텔레그램 연동 자리" note="금·은·구리 괴리율이 튈 때만 짧게 알려주는 채널로 연결하기 좋은 위치입니다." />
  </section>

  <section class="section">
    <AdSlot label="원자재 인라인 광고" note="가격표 아래에 자연스럽게 이어지는 반응형 광고 슬롯" />
  </section>
</BaseLayout>

<script define:vars={{ apiBase }}>
  const liveStatus = document.getElementById('commodity-live-status');
  const leadEl = document.getElementById('commodity-lead');
  const body = document.getElementById('commodity-body');

  const formatKrw = (value) =>
    new Intl.NumberFormat('ko-KR', {
      style: 'currency',
      currency: 'KRW',
      maximumFractionDigits: 0,
    }).format(Number(value));

  const formatUsd = (value) =>
    new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency: 'USD',
      maximumFractionDigits: 2,
    }).format(Number(value));

  const formatPercent = (value) => `${Number(value) > 0 ? '+' : ''}${Number(value).toFixed(2)}%`;
  const tone = (value) => (Number(value) >= 0 ? 'positive' : 'negative');

  const render = (rows) => {
    if (!body || !Array.isArray(rows)) return;

    body.innerHTML = rows.map((row) => `
      <tr>
        <td>
          <strong>${row.name}</strong>
          <div class="tiny">${row.code} · ${row.category}</div>
        </td>
        <td>${formatKrw(row.marketPriceKrw)}</td>
        <td>${formatKrw(row.navKrw)}</td>
        <td class="${tone(row.deviationPercent)}">${formatPercent(row.deviationPercent)}</td>
        <td>${formatKrw(row.volumeKrw)}</td>
        <td>${String(row.benchmarkSymbol).replace('.US', '')} · ${formatUsd(row.benchmarkPrice)}</td>
      </tr>
    `).join('');

    const lead = [...rows].sort((left, right) => Math.abs(Number(right.deviationPercent)) - Math.abs(Number(left.deviationPercent)))[0];
    if (lead && leadEl) {
      leadEl.textContent = `${lead.name} ${formatPercent(lead.deviationPercent)}`;
      leadEl.className = tone(lead.deviationPercent);
    }
  };

  const load = async () => {
    if (!apiBase) return;

    try {
      const response = await fetch(`${apiBase}/api/commodities`);
      const payload = await response.json();
      if (liveStatus) liveStatus.textContent = payload.fallback ? '폴백 데이터 표시 중' : `실시간 · ${payload.updatedAt}`;
      render(payload.rows);
    } catch {
      if (liveStatus) liveStatus.textContent = '실시간 연결 실패 · 폴백 유지';
    }
  };

  load();
  if (apiBase) window.setInterval(load, 3000);
</script>

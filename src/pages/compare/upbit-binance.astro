---
import BaseLayout from '../../components/BaseLayout.astro';
import { compareSnapshots } from '../../data/market';
import { sitePages } from '../../data/site';
import { formatPercent } from '../../lib/format';

const page = sitePages.find((item) => item.path === '/compare/upbit-binance')!;
const data = compareSnapshots['upbit-binance'];
---

<BaseLayout
  title={page.title}
  description={page.description}
  locale="ko"
  pathname={page.path}
>
  <section class="hero">
    <div class="eyebrow">거래소 비교</div>
    <h1>업비트 vs 바이낸스</h1>
    <p>{data.headline}</p>
  </section>

  <section class="section table-panel panel">
    <div class="section-header">
      <div>
        <h2>주요 코인 스프레드</h2>
        <p>{data.interpretation}</p>
      </div>
    </div>
    <table class="coin-table">
      <thead>
        <tr>
          <th>코인</th>
          <th>기준 거래소</th>
          <th>비교 거래소</th>
          <th>가격차</th>
          <th>스프레드</th>
        </tr>
      </thead>
      <tbody>
        {
          data.rows.map((row) => (
            <tr>
              <td>{row.symbol}</td>
              <td>{row.buy}</td>
              <td>{row.sell}</td>
              <td>{row.spreadKrw}</td>
              <td class={row.spreadPercent >= 0 ? 'positive' : 'negative'}>{formatPercent(row.spreadPercent)}</td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </section>

  <section class="section content-grid">
    <article class="copy-panel">
      <h2>왜 많이 보는 조합인가</h2>
      <p>
        업비트는 한국 개인 투자자 비중이 크고, 바이낸스는 글로벌 기준 가격 역할을 하기 때문에 이 조합만으로도
        한국 시장의 과열 또는 냉각을 빠르게 감지할 수 있습니다.
      </p>
    </article>
    <article class="copy-panel">
      <h2>주의점</h2>
      <ul class="bullet-list">
        <li>실제 차익 거래 가능성과 화면상 스프레드는 다를 수 있습니다.</li>
        <li>환율 급변 구간에서는 스프레드 해석이 왜곡될 수 있습니다.</li>
        <li>출금 지연과 규제 이슈를 같이 봐야 합니다.</li>
      </ul>
    </article>
  </section>
</BaseLayout>

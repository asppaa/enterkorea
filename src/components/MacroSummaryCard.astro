---
import { getApiBase } from '../lib/runtime';

const apiBase = getApiBase(import.meta.env.PUBLIC_KIMP_API_BASE, import.meta.env.DEV);
---

<aside class="macro-card" data-api-base={apiBase}>
  <header class="macro-head">
    <span class="macro-icon" aria-hidden="true">🌐</span>
    <div class="macro-title">
      <h2>MCP Macro Summary</h2>
      <p class="macro-subtitle">매일 아침 8시 자동 갱신 · 텔레그램·X·Threads 동시 발행</p>
    </div>
    <span class="macro-updated" data-updated>불러오는 중…</span>
  </header>
  <div class="macro-body" data-body>
    <div class="macro-skeleton" aria-hidden="true">
      <div></div><div></div><div></div><div></div><div></div>
    </div>
  </div>
  <footer class="macro-foot">
    <a href="https://t.me/macrobmacro" target="_blank" rel="noopener">📡 Telegram @macrobmacro</a>
    <a href="https://www.threads.net/@mcp5080" target="_blank" rel="noopener">🧵 Threads @mcp5080</a>
  </footer>
</aside>

<script>
  const SECTION_ICONS = ['🔑', '🇺🇸', '🇰🇷', '🌍', '🎯', '🛢️', '📅', '📊', '🪙', '🏠'];

  function isSectionHeader(line: string): boolean {
    const trimmed = line.trim();
    if (!trimmed) return false;
    return SECTION_ICONS.some((icon) => trimmed.startsWith(icon));
  }

  function isBullet(line: string): boolean {
    const trimmed = line.replace(/^\s+/, '');
    return trimmed.startsWith('• ') || trimmed.startsWith('• ');
  }

  function renderBlock(html: string): string {
    const lines = html.split('\n');
    const out: string[] = [];
    let buffer: string[] = [];
    let inList = false;

    const flushBuffer = () => {
      if (buffer.length) {
        out.push(`<p class="macro-line">${buffer.join('<br>')}</p>`);
        buffer = [];
      }
    };
    const closeList = () => {
      if (inList) {
        out.push('</ul>');
        inList = false;
      }
    };

    for (const raw of lines) {
      const line = raw;
      const trimmed = line.trim();
      if (!trimmed) {
        flushBuffer();
        closeList();
        continue;
      }
      if (isSectionHeader(line)) {
        flushBuffer();
        closeList();
        out.push(`<h3 class="macro-section">${trimmed}</h3>`);
        continue;
      }
      if (isBullet(line)) {
        flushBuffer();
        if (!inList) {
          out.push('<ul class="macro-list">');
          inList = true;
        }
        const item = trimmed.replace(/^•\s*/, '');
        out.push(`<li>${item}</li>`);
        continue;
      }
      // 일반 라인 — 줄바꿈 보존
      buffer.push(trimmed);
    }
    flushBuffer();
    closeList();
    return out.join('\n');
  }

  function formatUpdated(iso: string): string {
    if (!iso) return '';
    try {
      const d = new Date(iso);
      if (Number.isNaN(d.getTime())) return '';
      const now = new Date();
      const sameDay = d.toDateString() === now.toDateString();
      const hh = d.getHours().toString().padStart(2, '0');
      const mm = d.getMinutes().toString().padStart(2, '0');
      if (sameDay) return `오늘 ${hh}:${mm}`;
      const m = (d.getMonth() + 1).toString().padStart(2, '0');
      const day = d.getDate().toString().padStart(2, '0');
      return `${m}-${day} ${hh}:${mm}`;
    } catch {
      return '';
    }
  }

  async function loadMacro() {
    const card = document.querySelector<HTMLElement>('.macro-card');
    if (!card) return;
    const apiBase = card.dataset.apiBase || '';
    const body = card.querySelector<HTMLElement>('[data-body]');
    const updated = card.querySelector<HTMLElement>('[data-updated]');
    if (!body || !updated) return;
    try {
      const url = (apiBase || '') + '/api/macro-summary';
      const res = await fetch(url, { headers: { Accept: 'application/json' } });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      const html = (data.html || data.record?.html || '').toString();
      const updatedAt = (data.updatedAt || data.record?.updatedAt || '').toString();
      if (!html) {
        body.innerHTML = '<p class="macro-empty">아직 갱신된 요약이 없습니다. 매일 아침 8시 이후 표시됩니다.</p>';
        updated.textContent = '';
        return;
      }
      body.innerHTML = renderBlock(html);
      updated.textContent = `갱신 ${formatUpdated(updatedAt)}`;
    } catch (err) {
      body.innerHTML = '<p class="macro-error">요약을 불러오지 못했습니다. 잠시 후 다시 시도해주세요.</p>';
      updated.textContent = '';
    }
  }

  loadMacro();
</script>

<style>
  .macro-card {
    background: linear-gradient(160deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02));
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1.1rem;
    padding: 1.4rem 1.5rem;
    color: var(--color-text, #e8eaed);
    line-height: 1.65;
    font-size: 0.92rem;
    backdrop-filter: blur(8px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.18);
  }

  .macro-head {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    margin-bottom: 1rem;
    padding-bottom: 0.85rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  }

  .macro-icon {
    font-size: 1.5rem;
    line-height: 1.2;
  }

  .macro-title {
    flex: 1;
    min-width: 0;
  }

  .macro-title h2 {
    margin: 0;
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .macro-subtitle {
    margin: 0.25rem 0 0;
    font-size: 0.78rem;
    opacity: 0.55;
  }

  .macro-updated {
    flex-shrink: 0;
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.55);
    background: rgba(255, 255, 255, 0.06);
    border-radius: 999px;
    padding: 0.2rem 0.6rem;
    align-self: flex-start;
    margin-top: 0.15rem;
    white-space: nowrap;
  }

  .macro-body {
    font-size: 0.92rem;
  }

  .macro-section {
    margin: 1.1rem 0 0.5rem;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: -0.005em;
    color: rgba(255, 255, 255, 0.95);
  }
  .macro-section:first-child {
    margin-top: 0;
  }

  .macro-list {
    list-style: none;
    margin: 0 0 0.4rem;
    padding: 0;
  }

  .macro-list li {
    position: relative;
    padding: 0.15rem 0 0.15rem 1.05rem;
    margin-bottom: 0.35rem;
    line-height: 1.62;
  }

  .macro-list li::before {
    content: '·';
    position: absolute;
    left: 0.25rem;
    top: 0.05rem;
    font-weight: 800;
    color: rgba(255, 215, 107, 0.7);
    font-size: 1.1rem;
  }

  .macro-line {
    margin: 0 0 0.5rem;
  }

  .macro-body :global(b) {
    color: #ffd76b;
    font-weight: 700;
  }

  .macro-body :global(u) {
    text-decoration: underline;
    text-decoration-color: rgba(120, 200, 255, 0.55);
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .macro-foot {
    margin-top: 1.1rem;
    padding-top: 0.85rem;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.25rem;
    font-size: 0.78rem;
  }

  .macro-foot a {
    color: rgba(120, 200, 255, 0.85);
    text-decoration: none;
    transition: color 0.15s;
  }

  .macro-foot a:hover {
    color: rgba(150, 220, 255, 1);
  }

  .macro-skeleton {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .macro-skeleton > div {
    height: 0.85rem;
    border-radius: 0.3rem;
    background: linear-gradient(90deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.04));
    background-size: 200% 100%;
    animation: macro-shimmer 1.5s ease-in-out infinite;
  }
  .macro-skeleton > div:nth-child(2) { width: 88%; }
  .macro-skeleton > div:nth-child(3) { width: 72%; }
  .macro-skeleton > div:nth-child(4) { width: 80%; }
  .macro-skeleton > div:nth-child(5) { width: 60%; }

  @keyframes macro-shimmer {
    0% { background-position: -100% 0; }
    100% { background-position: 100% 0; }
  }

  .macro-empty,
  .macro-error {
    margin: 0;
    padding: 0.75rem 0;
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.88rem;
  }
  .macro-error {
    color: rgba(255, 150, 150, 0.85);
  }

  /* 데스크탑: sticky 사이드바로 활용 가능 */
  @media (min-width: 1024px) {
    .macro-card {
      position: sticky;
      top: 1.25rem;
      max-height: calc(100vh - 2.5rem);
      overflow-y: auto;
      scrollbar-width: thin;
      scrollbar-color: rgba(255, 255, 255, 0.15) transparent;
    }
    .macro-card::-webkit-scrollbar {
      width: 6px;
    }
    .macro-card::-webkit-scrollbar-thumb {
      background: rgba(255, 255, 255, 0.15);
      border-radius: 3px;
    }
  }
</style>

---
import '../styles/global.css';
import Header from './Header.astro';
import Footer from './Footer.astro';
import { siteConfig, type Locale } from '../data/site';

const {
  title,
  description,
  locale = 'ko',
  pathname = '/',
  image = '/og-cover.png',
  structuredData,
} = Astro.props as {
  title: string;
  description: string;
  locale?: Locale;
  pathname?: string;
  image?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
};

const siteUrl = Astro.site?.toString() || siteConfig.siteUrl;
const canonical = new URL(pathname, siteUrl).toString();
const ogImage = new URL(image, siteUrl).toString();
const jsonLd = structuredData ? JSON.stringify(structuredData) : null;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#08111f" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&family=Noto+Sans+KR:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="ko_KR" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <title>{title}</title>
    {jsonLd && <script type="application/ld+json" set:html={jsonLd}></script>}
    <script
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1128410732841279"
      crossorigin="anonymous"
    ></script>
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-FWPKKDCTST"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-FWPKKDCTST');
    </script>
  </head>
  <body>
    <div class="shell">
      <Header locale={locale} pathname={pathname} />
      <main class="page">
        <slot />
      </main>
      <Footer locale={locale} />
    </div>
  </body>
</html>

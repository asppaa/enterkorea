---
import Header from './Header.astro';
import Footer from './Footer.astro';
import { getLocaleHref, siteConfig, type Locale } from '../data/site';
import '../styles/global.css';

type AlternateLink = { lang: string; path: string };

const {
  title,
  description,
  locale = 'ko',
  pathname = '/',
  alternates = [],
  image = '/favicon.svg',
  structuredData,
} = Astro.props as {
  title: string;
  description: string;
  locale?: Locale;
  pathname?: string;
  alternates?: AlternateLink[];
  image?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
};

const siteUrl = Astro.site?.toString() || siteConfig.siteUrl;
const canonical = new URL(pathname, siteUrl).toString();
const ogImage = new URL(image, siteUrl).toString();
const jsonLd = structuredData ? JSON.stringify(structuredData) : null;
const alternateTags =
  alternates.length > 0
    ? alternates
    : [
        { lang: locale, path: pathname },
        { lang: locale === 'ko' ? 'en' : 'ko', path: getLocaleHref(pathname, locale === 'ko' ? 'en' : 'ko') },
      ];
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#08111f" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&family=Noto+Sans+KR:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    {alternateTags.map((item) => <link rel="alternate" hreflang={item.lang} href={new URL(item.path, siteUrl).toString()} />)}
    <link rel="alternate" hreflang="x-default" href={new URL(getLocaleHref(pathname, 'ko'), siteUrl).toString()} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={locale === 'ko' ? 'ko_KR' : 'en_US'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <title>{title}</title>
    {jsonLd && <script type="application/ld+json" set:html={jsonLd}></script>}
  </head>
  <body>
    <div class="shell">
      <Header locale={locale} pathname={pathname} />
      <main class="page">
        <slot />
      </main>
      <Footer locale={locale} />
    </div>
  </body>
</html>

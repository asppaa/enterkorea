---
import { siteConfig, type Locale } from '../data/site';

const { locale = 'ko', pathname = '/' } = Astro.props as {
  locale?: Locale;
  pathname?: string;
};

const nav = siteConfig.topNav[locale];
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="brand-mark">
      <span class="brand-chip">KB</span>
      <span class="brand-title">
        <strong>{siteConfig.brand[locale]}</strong>
        <span>한국 프리미엄 관측소</span>
      </span>
    </a>
    <nav class="top-nav" aria-label="주요 메뉴">
      {
        nav.map((item) => (
          <a href={item.href} aria-current={pathname === item.href ? 'page' : undefined}>
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

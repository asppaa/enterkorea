---
const {
  label = '구글 애드센스 자리',
  note = '애드센스 연결 전까지는 자리만 먼저 확보해 둔 상태입니다.',
  compact = false,
} = Astro.props as {
  label?: string;
  note?: string;
  compact?: boolean;
};
---

<aside class:list={['ad-slot', compact && 'ad-slot-compact']} aria-label={label}>
  <span>AD</span>
  <strong>{label}</strong>
  <p>{note}</p>
</aside>

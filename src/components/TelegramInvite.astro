---
const telegramUrl = import.meta.env.PUBLIC_TELEGRAM_CHANNEL_URL || 'https://t.me/kimpboard';
const telegramHandle = import.meta.env.PUBLIC_TELEGRAM_CHANNEL_HANDLE || '@KIMPBOARD';
const telegramQrImage = import.meta.env.PUBLIC_TELEGRAM_QR_IMAGE_URL || '/telegram-kimpboard-qr.svg';
const xUrl = import.meta.env.PUBLIC_X_PROFILE_URL || 'https://x.com/lifelagos1';
const xHandle = import.meta.env.PUBLIC_X_HANDLE || '@lifelagos1';

const {
  title = '텔레그램 채널',
  note = '사이트에서 숫자를 보고, 텔레그램과 X에서는 더 빠른 요약과 링크 큐레이션을 받는 구조로 연결합니다.',
  compact = false,
} = Astro.props as {
  title?: string;
  note?: string;
  compact?: boolean;
};

const isReady = Boolean(telegramUrl);
const hasQr = Boolean(telegramQrImage);
const hasX = Boolean(xUrl);
---

<section class:list={['telegram-card', compact && 'telegram-card-compact']}>
  <div class="telegram-copy">
    <div class="eyebrow">텔레그램 유입 동선</div>
    <h2>{title}</h2>
    <p>{note}</p>
    <ul class="bullet-list">
      <li>사이트: 숫자와 비교를 빠르게 확인</li>
      <li>텔레그램: 요약 해설, 위험 신호, 빠른 링크 전달</li>
      <li>X: 짧은 코멘트와 업데이트 흐름 확인</li>
      <li>둘 다 이미 연결돼 있어 바로 들어갈 수 있습니다</li>
    </ul>
  </div>
  <div class="telegram-side">
    {
      isReady ? (
        <a class="telegram-qr telegram-qr-link" href={telegramUrl} target="_blank" rel="noreferrer">
          {hasQr ? <img src={telegramQrImage} alt={`${telegramHandle} QR`} /> : <strong>QR</strong>}
          <span>{telegramHandle}</span>
        </a>
      ) : (
        <div class="telegram-qr">
          <strong>QR</strong>
          <span>채널 개설 예정</span>
        </div>
      )
    }
    <div class="social-stack">
      {
        isReady ? (
          <a class="telegram-link" href={telegramUrl} target="_blank" rel="noreferrer">
            텔레그램 채널 열기
          </a>
        ) : (
          <div class="telegram-link telegram-link-muted">텔레그램 링크 자리 확보</div>
        )
      }
      {
        hasX ? (
          <a class="telegram-link telegram-link-secondary" href={xUrl} target="_blank" rel="noreferrer">
            X {xHandle}
          </a>
        ) : (
          <div class="telegram-link telegram-link-muted">X 링크 자리 확보</div>
        )
      }
    </div>
  </div>
</section>

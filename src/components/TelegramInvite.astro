---
const telegramUrl = import.meta.env.PUBLIC_TELEGRAM_CHANNEL_URL || '';
const telegramHandle = import.meta.env.PUBLIC_TELEGRAM_CHANNEL_HANDLE || '@your_channel';

const {
  title = '텔레그램 채널',
  note = '사이트에서 숫자를 보고, 텔레그램에서는 더 빠른 요약과 위험 신호를 받는 구조를 미리 깔아둡니다.',
  compact = false,
} = Astro.props as {
  title?: string;
  note?: string;
  compact?: boolean;
};

const isReady = Boolean(telegramUrl);
---

<section class:list={['telegram-card', compact && 'telegram-card-compact']}>
  <div class="telegram-copy">
    <div class="eyebrow">텔레그램 유입 동선</div>
    <h2>{title}</h2>
    <p>{note}</p>
    <ul class="bullet-list">
      <li>사이트: 숫자와 비교를 빠르게 확인</li>
      <li>텔레그램: 요약 해설, 위험 신호, 링크 큐레이션</li>
      <li>채널 개설 전에도 링크 자리와 QR 자리를 먼저 확보해 둡니다</li>
    </ul>
  </div>
  <div class="telegram-side">
    <div class="telegram-qr">
      <strong>QR</strong>
      <span>{isReady ? telegramHandle : '채널 개설 예정'}</span>
    </div>
    {
      isReady ? (
        <a class="telegram-link" href={telegramUrl} target="_blank" rel="noreferrer">
          텔레그램 채널 열기
        </a>
      ) : (
        <div class="telegram-link telegram-link-muted">링크 자리 확보 완료</div>
      )
    }
  </div>
</section>
